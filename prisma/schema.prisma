  fechaCreacion                                               DateTime?        @db.Timestamp(6)
  modificadoPor                                               String?          @db.VarChar(50)
  fechaModificacion                                           DateTime?        @db.Timestamp(6)
  rel_movimiento_rel_movimiento_idAlmacenDestinoTocat_almacen rel_movimiento[] @relation("rel_movimiento_idAlmacenDestinoTocat_almacen")
  rel_movimiento_rel_movimiento_idAlmacenOrigenTocat_almacen  rel_movimiento[] @relation("rel_movimiento_idAlmacenOrigenTocat_almacen")
