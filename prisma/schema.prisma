generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model asignacion_diaria {
  idAsignacion    String    @id @db.VarChar(50)
  FOLIO           Int?
  FECHA           DateTime? @db.Date
  LINEA           Int?
  JORNADA         Int?
  UNIDAD          String?   @db.VarChar(50)
  OPERADOR        String?   @db.VarChar(50)
  NOMBRE_COMPLETO String?   @map("NOMBRE COMPLETO") @db.VarChar(50)
  HORA_SALIDA     DateTime? @map("HORA SALIDA") @db.Time(6)
}

model bin_ticket {
  idticket                 String                @id(map: "bin_ticket_pk") @db.VarChar(50)
  fecha                    DateTime?             @db.Date
  fechahora                DateTime?             @db.Timestamp(6)
  tiporeparacion           String?               @db.VarChar(50)
  folio                    String?               @db.VarChar(50)
  idautobus                String?               @db.VarChar(50)
  numeroeconomico          String?               @db.VarChar(50)
  idruta                   String?               @db.VarChar(50)
  idoperador               String?               @db.VarChar(50)
  nombreoperador           String?               @db.VarChar(50)
  idusuario                String?               @db.VarChar(50)
  idreporta                String?               @db.VarChar(50)
  iddispositivo            String?               @db.VarChar(50)
  iddispositivot           String?               @db.VarChar(50)
  idfalla                  String?               @db.VarChar(50)
  idcategoria              String?               @db.VarChar(50)
  idprioridad              String?               @db.VarChar(50)
  idestado                 String?               @db.VarChar(50)
  idtecnico                String?               @db.VarChar(50)
  comentarios              String?
  areatrabajo              String?               @db.VarChar(50)
  fecharesolucion          DateTime?             @db.Timestamp(6)
  creadopor                String?               @db.VarChar(80)
  fechacreacion            DateTime?             @db.Timestamp(6)
  modificadopor            String?               @db.VarChar(50)
  fechamodificacion        DateTime?             @db.Timestamp(6)
  estatusrep               String?               @db.VarChar(50)
  msjenviado               String?               @db.VarChar(50)
  foliocliente             String?               @db.VarChar(50)
  reasignado               String?               @db.VarChar(50)
  bloque                   String?               @db.VarChar(50)
  locacion                 String?               @db.VarChar(50)
  alias                    String?               @db.VarChar(50)
  descripcion              String?
  fechareportecliente      DateTime?             @db.Timestamp(6)
  fechatecnico             DateTime?             @db.Timestamp(6)
  fechamesa                DateTime?             @db.Timestamp(6)
  tiempototal              String?               @db.VarChar(50)
  tiemporetardounidad      String?               @db.VarChar(50)
  imagenfalla1             String?
  imagenfalla2             String?
  imagenfalla3             String?
  video                    String?
  fechacat                 DateTime?             @db.Date
  folionumerocliente       String?               @db.VarChar(50)
  confirmarnuevaincidencia String?               @db.VarChar(255)
  alertafoliosabiertos     String?               @db.VarChar(50)
  resetbot                 String?               @db.VarChar(50)
  check_in                 DateTime?             @db.Timestamp(6)
  idempresa                String?               @db.VarChar(20)
  num_folio                Int?
  cat_empresa              cat_empresa?          @relation(fields: [idempresa], references: [idEmpresa], onDelete: NoAction, onUpdate: NoAction, map: "bin_ticket_cat_empresa_fk")
  cat_autobus              cat_autobus?          @relation(fields: [idautobus], references: [idAutobus], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_autobus")
  cat_categoria            cat_categoria?        @relation(fields: [idcategoria], references: [idCategoria], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_categoria")
  cat_dispositivo          cat_dispositivo?      @relation(fields: [iddispositivo], references: [idDispositivo], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_dispositivo")
  cat_dispositivo_t        cat_dispositivo_t?    @relation(fields: [iddispositivot], references: [idDispositivoT], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_dispositivo_t")
  estado                   cat_estado_r?         @relation(fields: [idestado], references: [idEstadoR], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_estado")
  cat_falla                cat_falla?            @relation(fields: [idfalla], references: [idFalla], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_falla")
  cat_prioridad            cat_prioridad?        @relation(fields: [idprioridad], references: [idPrioridad], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_prioridad")
  cat_reporta              cat_reporta?          @relation(fields: [idreporta], references: [idReporta], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_reporta")
  cat_ruta                 cat_ruta?             @relation(fields: [idruta], references: [idRuta], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_ruta")
  cat_tecnicos             cat_usuarios_app?     @relation(fields: [idtecnico], references: [idUsuarioApp], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_tecnico")
  cat_tipo_reparacion      cat_tipo_reparacion?  @relation(fields: [tiporeparacion], references: [idtipoReparacion], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_tipo_reparacion")
  bin_ticket_detail        bin_ticket_detail[]
  solicitud_refaccion      solicitud_refaccion[]
}

model bin_ticket_detail {
  idDetalle         String             @id(map: "bin_ticket_detail_pk") @db.VarChar(50)
  idTicket          String?            @db.VarChar(50)
  fechaHora         DateTime?          @db.Timestamp(6)
  folio             String?            @db.VarChar(50)
  idAutobus         String?            @db.VarChar(50)
  numeroeconomico   String?            @db.VarChar(50)
  idRuta            String?            @db.VarChar(50)
  idUsuario         String?            @db.VarChar(50)
  idDispositivo     String?            @db.VarChar(50)
  idDispositivoT    String?            @db.VarChar(50)
  idFalla           String?            @db.VarChar(50)
  idCategoria       String?            @db.VarChar(50)
  idPrioridad       String?            @db.VarChar(50)
  idEstado          String?            @db.VarChar(50)
  idTecnico         String?            @db.VarChar(50)
  Diagnostico       String?
  Reparacion        String?
  comentarios       String?
  areatrabajo       String?            @db.VarChar(50)
  imagen1           String?
  imagen2           String?
  imagen3           String?
  video             String?
  fechaResolucion   DateTime?          @db.Timestamp(6)
  creadoPor         String?            @db.VarChar(50)
  fechaCreacion     DateTime?          @db.Timestamp(6)
  modificadoPor     String?            @db.VarChar(50)
  fechaModificacion DateTime?          @db.Timestamp(6)
  GpsInicial        String?            @db.VarChar(50)
  gpsModifica       String?            @db.VarChar(50)
  bin_ticket        bin_ticket?        @relation(fields: [idTicket], references: [idticket], onDelete: NoAction, onUpdate: NoAction, map: "bin_ticket_detail_bin_ticket_fk")
  cat_autobus       cat_autobus?       @relation(fields: [idAutobus], references: [idAutobus], onDelete: NoAction, onUpdate: NoAction, map: "fk_detail_autobus")
  cat_categoria     cat_categoria?     @relation(fields: [idCategoria], references: [idCategoria], onDelete: NoAction, onUpdate: NoAction, map: "fk_detail_categoria")
  cat_dispositivo   cat_dispositivo?   @relation(fields: [idDispositivo], references: [idDispositivo], onDelete: NoAction, onUpdate: NoAction, map: "fk_detail_dispositivo")
  cat_dispositivo_t cat_dispositivo_t? @relation(fields: [idDispositivoT], references: [idDispositivoT], onDelete: NoAction, onUpdate: NoAction, map: "fk_detail_dispositivo_t")
  cat_estado_r      cat_estado_r?      @relation(fields: [idEstado], references: [idEstadoR], onDelete: NoAction, onUpdate: NoAction, map: "fk_detail_estado")
  cat_falla         cat_falla?         @relation(fields: [idFalla], references: [idFalla], onDelete: NoAction, onUpdate: NoAction, map: "fk_detail_falla")
  cat_tecnicos      cat_usuarios_app?  @relation(fields: [modificadoPor], references: [idUsuarioApp], onDelete: NoAction, onUpdate: NoAction, map: "fk_detail_modificado_por")
  cat_prioridad     cat_prioridad?     @relation(fields: [idPrioridad], references: [idPrioridad], onDelete: NoAction, onUpdate: NoAction, map: "fk_detail_prioridad")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model buscar_conductor {
  nombre          String? @db.VarChar(50)
  Apellidomaterno String? @db.VarChar(50)
  Apellidopaterno String? @db.VarChar(50)

  @@ignore
}

model campa_a {
  idRegistroCampa_a String            @id @map("idRegistroCampaña") @db.VarChar(50)
  fechaHora         DateTime?         @db.Timestamp(6)
  idAutobus         String?           @db.VarChar(50)
  idRuta            String?           @db.VarChar(50)
  numeroEconomico   String?           @db.VarChar(50)
  reparacion        String?           @db.VarChar(50)
  idFalla           String?           @db.VarChar(50)
  idTecnico         String?           @db.VarChar(50)
  idEstado          String?           @db.VarChar(50)
  cat_autobus       cat_autobus?      @relation(fields: [idAutobus], references: [idAutobus], onDelete: NoAction, onUpdate: NoAction, map: "fk_campana_autobus")
  cat_estado_r      cat_estado_r?     @relation(fields: [idEstado], references: [idEstadoR], onDelete: NoAction, onUpdate: NoAction, map: "fk_campana_estado_r")
  cat_falla         cat_falla?        @relation(fields: [idFalla], references: [idFalla], onDelete: NoAction, onUpdate: NoAction, map: "fk_campana_falla")
  cat_ruta          cat_ruta?         @relation(fields: [idRuta], references: [idRuta], onDelete: NoAction, onUpdate: NoAction, map: "fk_campana_ruta")
  cat_tecnicos      cat_usuarios_app? @relation(fields: [idTecnico], references: [idUsuarioApp], onDelete: NoAction, onUpdate: NoAction, map: "fk_campana_tecnico")

  @@map("campaña")
}

model cat_almacen {
  idAlmacen                                                   String           @id @db.VarChar(50)
